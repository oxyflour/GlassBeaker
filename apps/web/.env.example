# Required for the CopilotKit built-in agent.
OPENAI_API_KEY=sk-xx
OPENAI_BASE_URL=http://localhost:11434/v1

# Optional: override the default public preview ESM host (defaults to https://esm.sh).
NEXT_PUBLIC_PREVIEW_ESM_BASE_URL=https://your-esm-host.example.com

# Optional: override the default model used by the built-in agent.
COPILOTKIT_MODEL=openai:gpt-oss:20b
