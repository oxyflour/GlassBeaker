{
  "name": "glassbeaker-desktop",
  "version": "0.1.0",
  "author": "GlassBeaker",
  "description": "Minimal Next.js + Electron desktop shell",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "package:dir": "electron-builder --dir --publish never",
    "dist": "electron-builder --publish never"
  },
  "build": {
    "appId": "com.glassbeaker.app",
    "productName": "GlassBeaker",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "41.0.4",
    "electron-builder": "26.8.1"
  }
}
